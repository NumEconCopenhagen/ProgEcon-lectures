\begin_layout Subsection
Document stationarity
\end_layout

\begin_layout Standard
Run the model with the baseline parameters.
 Let the simulator return the last 200 periods and denote these periods by 
\begin_inset Formula $t=-200,\dots,-1$
\end_inset

 (where 
\begin_inset Formula $t=-1$
\end_inset

 is the final simulated period).
\end_layout

\begin_layout Enumerate
Compute the selected moments (unemployment rate,
 mean and standard deviation of 
\begin_inset Formula $\log y$
\end_inset

) using the first half (
\begin_inset Formula $t=-200,\dots,-101$
\end_inset

) and the second half (
\begin_inset Formula $t=-100,\dots,-1$
\end_inset

).
 Show that the moments are (almost) identical.
 
\end_layout

\begin_layout Enumerate
Compare the distribution of 
\begin_inset Formula $\log y$
\end_inset

