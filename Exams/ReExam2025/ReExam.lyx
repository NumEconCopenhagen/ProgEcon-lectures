\begin_layout Section
Labor market simulation
\end_layout

\begin_layout Standard
In this assignment you will build and simulate a simple labor-market model with unemployment,
 human capital dynamics,
 and two worker types:
 low-skilled (
\begin_inset Formula $s=L$
\end_inset

) and high-skilled (
\begin_inset Formula $s=H$
\end_inset

).
 The goal is to simulate forward until the cross-sectional distribution does not change anymore,
 and thus is (approximately) stationary.
 You will then use the simulation to compare outcomes for low- and high-skilled workers.
\end_layout

\begin_layout Standard
You can use the code in 
\begin_inset ERT
status open

\begin_layout Plain Layout


\backslash
lstinline{LaborMarketModel.py}
\end_layout

\end_inset

 uploaded together with the exam as your starting point.
\end_layout

\begin_layout Paragraph*
State variables
\end_layout

\begin_layout Standard
For each individual 
\begin_inset Formula $i$
\end_inset

 at time 
\begin_inset Formula $t$
\end_inset

 (think of 
\begin_inset Formula $t$
\end_inset

 as months),
 the state is 
\begin_inset Formula $(e_{it},d_{it},k_{it},s_{i}),$
\end_inset

where:
 
\end_layout

\begin_layout Itemize
\begin_inset Formula $e_{it}\in\{0,1\}$
\end_inset

 is employment status (
\begin_inset Formula $1$
\end_inset

 employed,
 
\begin_inset Formula $0$
\end_inset

 unemployed),
 
\end_layout

\begin_layout Itemize
\begin_inset Formula $d_{it}\in\{0,1,2,\dots\}$
\end_inset

 is unemployment duration (months),
 
\begin_inset Formula $d_{it}=0$
\end_inset

 if employed,
 
\end_layout

\begin_layout Itemize
\begin_inset Formula $k_{it}$
\end_inset

 is 
\emph on
log human capital
\emph default
,
 
\end_layout

\begin_layout Itemize
\begin_inset Formula $s_{i}\in\{L,H\}$
\end_inset

 is the worker type.
 
\end_layout

\begin_layout Paragraph*
Human capital
\end_layout

\begin_layout Standard
Log human capital follows an AR(1) process around a type-specific mean,
 
\begin_inset Formula $\mu_{s_{i}}$
\end_inset

,
 with depreciation,
 
\begin_inset Formula $\delta_{u}$
\end_inset

,
 during unemployment:
 
\begin_inset Formula 
\begin{equation}
k_{i,t+1}=\mu_{s_{i}}+\rho\,(k_{it}-\mu_{s_{i}})-\delta_{u}\cdot\mathbf{1}\{e_{it}=0\}+\sigma_{h}\,\eta_{i,t+1},\qquad\eta_{i,t+1}\sim\mathcal{N}(0,1).
\end{equation}

\end_inset


\end_layout

\begin_layout Paragraph*
Income
\end_layout

\begin_layout Standard
While employed,
 income has an idiosyncratic wage shock:
 
\begin_inset Formula 
\begin{equation}
y_{it}=\begin{cases}
\exp(a_{s_{i}}+k_{it}+\sigma_{y}\,\xi_{it}), & \text{if }e_{it}=1,\;\xi_{it}\sim\mathcal{N}(0,1),\\
b\cdot\exp(a_{s_{i}}+k_{it}), & \text{if }e_{it}=0.
\end{cases}
\end{equation}

\end_inset

Here 
\begin_inset Formula $b\in(0,1)$
\end_inset

 is a replacement rate.
\end_layout

\begin_layout Paragraph*
Labor market transitions
\end_layout

\begin_layout Standard
Employment evolves as follows:
 
\end_layout

\begin_layout Itemize
If employed (
\begin_inset Formula $e_{it}=1$
\end_inset

):
 with probability 
\begin_inset Formula $\texttt{sep\_rate}$
\end_inset

 the worker separates and becomes unemployed next period,
 
\begin_inset Formula $e_{i,t+1}=0$
\end_inset

,
 with 
\begin_inset Formula $d_{i,t+1}=1$
\end_inset

.
 
\end_layout

\begin_layout Itemize
If unemployed (
\begin_inset Formula $e_{it}=0$
\end_inset

) with duration 
\begin_inset Formula $d_{it}\geq1$
\end_inset

:
 with probability 
\begin_inset Formula $f_{s_{i}}(d_{it})$
\end_inset

 the worker finds a job and becomes employed next period (
\begin_inset Formula $e_{i,t+1}=1$
\end_inset

 and 
\begin_inset Formula $d_{i,t+1}=0$
\end_inset

).
 Otherwise they remain unemployed and duration increases by one:
 
\begin_inset Formula $d_{i,t+1}=d_{it}+1$
\end_inset

.
 
\end_layout

\begin_layout Paragraph*
Job-finding rate with duration dependence
\end_layout

\begin_layout Standard
The job-finding probability declines with unemployment duration,
\begin_inset Formula 
\begin{equation}
f_{s}(d)=\max\left\{ \min\left\{ 1,\;f_{0,s}\exp\big(-\lambda_{s}(d-1)\big)\right\} ,0.05\right\} ,\qquad d\ge1,
\end{equation}

\end_inset

but never falls below 
\begin_inset Formula $0.05$
\end_inset

.
\end_layout

\begin_layout Paragraph*
Initialization (given in the code)
\end_layout

\begin_layout Standard
To start the simulation at 
\begin_inset Formula $t=0$
\end_inset

,
 use a simple random initialization:
 
\end_layout

\begin_layout Itemize
Draw types:
 
\begin_inset Formula $s_{i}=H$
\end_inset

 with probability 
\begin_inset Formula $0.40$
\end_inset

 (otherwise 
\begin_inset Formula $s_{i}=L$
\end_inset

).
 
\end_layout

\begin_layout Itemize
Draw initial employment:
 Employed with probability 
\begin_inset Formula $0.92$
\end_inset

.
 
\end_layout

\begin_layout Itemize
If employed,
 set initial duration:
 
\begin_inset Formula $d_{i0}=0$
\end_inset

 .
\end_layout

\begin_layout Itemize
If unemployed draw 
\begin_inset Formula $d_{i0}$
\end_inset

 uniformly from 
\begin_inset Formula $\{1,2,3,4,5,6\}$
\end_inset

.
 
\end_layout

\begin_layout Itemize
Draw initial human capital from a stationary distribution of the AR(1) around 
\begin_inset Formula $\mu_{s_{i}}$
\end_inset

 (ignoring unemployment depreciation at initialization):
\begin_inset Formula 
\[
k_{i0}=\mu_{s_{i}}+\frac{\sigma_{h}}{\sqrt{1-\rho^{2}}}\,z_{i},\qquad z_{i}\sim\mathcal{N}(0,1).
\]

\end_inset


\end_layout

\begin_layout Standard
