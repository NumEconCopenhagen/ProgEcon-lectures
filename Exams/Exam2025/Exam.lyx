\begin_layout Section
Exchange economy
\end_layout

\begin_layout Standard
We consider an 
\emph on
exchange economy
\emph default
 with two consumers,
 
\begin_inset Formula $A$
\end_inset

 and 
\begin_inset Formula $B$
\end_inset

,
 and two goods,
 
\begin_inset Formula $x_{1}$
\end_inset

 and 
\begin_inset Formula $x_{2}$
\end_inset

.
 The total endowment of each good is always 
\begin_inset Formula $1$
\end_inset

.
 Consumer 
\begin_inset Formula $A$
\end_inset

's endowment is 
\begin_inset Formula $\boldsymbol{\omega}^{A}=(\omega_{1}^{A},\omega_{2}^{A})$
\end_inset

.
 Consumer 
\begin_inset Formula $B$
\end_inset

's endowment is 
\begin_inset Formula $\boldsymbol{\omega}^{B}=(\omega_{1}^{B},\omega_{2}^{B})=(1-\omega_{1}^{A},1-\omega_{2}^{A})$
\end_inset

.
 Prices are 
\begin_inset Formula $\boldsymbol{p}=(p_{1},p_{2})$
\end_inset

.
 The numeraire is 
\begin_inset Formula $p_{2}=1.$
\end_inset


\end_layout

\begin_layout Standard
Both consumers have utility functions on the Constant Elasticity of Substitution (CES) form
\begin_inset Formula 
\begin{align}
u(x_{1},x_{2};\alpha,\beta) & =\left(\alpha x_{1}^{\rho}+\beta x_{2}^{\rho}\right)^{1/\rho},\qquad\rho\neq0.\label{eq:u}
\end{align}

\end_inset

The indifference curve for utility level 
\begin_inset Formula $u$
\end_inset

 can be written
\begin_inset Formula 
\begin{equation}
x_{2}(u;\alpha,\beta)=\left(\frac{u^{\rho}-\alpha x_{1}^{\rho}}{\beta}\right)^{\frac{1}{\rho}}.\label{eq:indifference}
\end{equation}

\end_inset


\end_layout

\begin_layout Standard
Defining 
\begin_inset Formula $\sigma=\frac{1}{1-\rho}$
\end_inset

 and 
\begin_inset Formula $m=p_{1}\omega_{1}+\omega_{2}$
\end_inset

.
 The demand functions are
\begin_inset Formula 
\begin{align}
x_{1}(p_{1},m) & =\alpha^{\sigma}p_{1}^{-\sigma}\frac{m}{\alpha^{\sigma}p_{1}^{1-\sigma}+\beta^{\sigma}}\label{eq:demand1}\\
x_{2}(p_{1},m) & =\beta^{\sigma}\frac{m}{\alpha^{\sigma}p_{1}^{1-\sigma}+\beta^{\sigma}}.\label{eq:demand2}
\end{align}

\end_inset


\end_layout

\begin_layout Standard
Consumer 
\begin_inset Formula $A$
\end_inset

 has preference parameters 
\begin_inset Formula $\alpha^{A}$
\end_inset

,
 
\begin_inset Formula $\beta^{A}$
\end_inset

 and 
\begin_inset Formula $\rho^{A}$
\end_inset

,
 and income 
\begin_inset Formula 
\[
m^{A}=p_{1}\omega_{1}^{A}+\omega_{2}^{A}.
\]

\end_inset

Consumer 
\begin_inset Formula $B$
\end_inset

 has preference parameters 
\begin_inset Formula $\alpha^{B}$
\end_inset

,
 
\begin_inset Formula $\beta^{B}$
\end_inset

 and 
\begin_inset Formula $\rho^{B}$
\end_inset

,
 and income 
\begin_inset Formula 
\[
m^{B}=p_{1}\omega_{1}^{B}+\omega_{2}^{B}.
\]

\end_inset


\end_layout

\begin_layout Standard
In equilibrium excess demand is zero.
 This implies that all equilibrium prices is a solution to 
\begin_inset Formula 
\begin{equation}
\epsilon_{1}(p_{1})\equiv x_{1}^{A\star}(p_{1},m^{A})+x_{1}^{B\star}(p_{1},m^{B})-1=0.\label{eq:excess_demand1}
\end{equation}

\end_inset


\end_layout

\begin_layout Paragraph*
Calibration.
\end_layout

\begin_layout Standard
The preference parameters are 
\begin_inset Formula $\alpha^{A}=\beta^{B}=1$
\end_inset

,
 
\begin_inset Formula $\beta^{A}=\alpha^{B}=\left(12/37\right)^{3}$
\end_inset

 and 
\begin_inset Formula $\rho^{A}=\rho^{B}=-2$
\end_inset

.
 The endowments are 
\begin_inset Formula $\omega_{1}^{A}=1.0-10^{-8}$
\end_inset

 and 
\begin_inset Formula $\omega_{2}^{A}=10^{-8}$
\end_inset

.
\end_layout

